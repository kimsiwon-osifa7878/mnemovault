# OpenRouter API Key
OPENROUTER_API_KEY=xxx

# Ollama URL
#OLLAMA_URL=http://localhost:11434
OLLAMA_URL=http://localhost:11434
#NEXT_PUBLIC_OLLAMA_MODEL=gemma4:e4b
NEXT_PUBLIC_OLLAMA_MODEL=gemma4:26b

# OpenRouter Free Models (comma-separated)
OPENROUTER_FREE_MODELS=google/gemma-4-26b-a4b-it:free,google/gemma-4-31b-it:free,z-ai/glm-4.5-air:free,minimax/minimax-m2.5:free

# LLM request policy (milliseconds/retries)
# - 0 timeout means "no timeout"
# - global keys override provider-specific keys
LLM_REQUEST_TIMEOUT_MS=120000
LLM_REQUEST_RETRIES=1
OPENROUTER_REQUEST_TIMEOUT_MS=240000
OPENROUTER_REQUEST_RETRIES=1
OLLAMA_REQUEST_TIMEOUT_MS=900000
OLLAMA_REQUEST_RETRIES=0
#
# Note: Node's global fetch uses Undici with a 300s default headers/body wait; this app routes LLM calls
# through undici with timeouts aligned to OLLAMA_REQUEST_TIMEOUT_MS / OPENROUTER_REQUEST_TIMEOUT_MS so slow
# local Ollama generation (>5m) does not fail with a false "network_error".
