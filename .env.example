# OpenRouter
# OpenRouter provider is enabled only when BOTH values below are non-empty.
OPENROUTER_API_KEY=
OPENROUTER_MODELS=
#OPENROUTER_MODELS=openrouter/auto,google/gemma-4-31b-it,z-ai/glm-5.1

# Ollama (client-side)
NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434

# Request policy (provider-specific)
# Use 0 timeout to disable timeout.
OPENROUTER_REQUEST_TIMEOUT_MS=240000
OPENROUTER_REQUEST_RETRIES=1
OLLAMA_REQUEST_TIMEOUT_MS=900000
OLLAMA_REQUEST_RETRIES=0
